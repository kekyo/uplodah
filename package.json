{
  "name": "uplodah",
  "description": "Universal file upload/download server.",
  "version": "0.1.0",
  "keywords": [
    "upload",
    "download",
    "file",
    "server",
    "typescript",
    "react",
    "fastify"
  ],
  "author": "Kouji Matsui",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kekyo/uplodah"
  },
  "homepage": "https://github.com/kekyo/uplodah",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "uplodah": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "metadata": "screw-up metadata",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "npm run metadata && vite build",
    "build:ui": "npm run metadata && BUILD_TARGET=ui vite build",
    "dev": "npm run metadata && vite dev",
    "test": "npm run build && vitest run",
    "start": "npm run build && node dist/cli.mjs -c ./dev/config.json -d ./dev/storage",
    "pack": "npm run build && screw-up pack --pack-destination artifacts/"
  },
  "dependencies": {
    "@emotion/react": ">=11.14.0",
    "@emotion/styled": ">=11.14.1",
    "@fastify/static": ">=7.0.4",
    "@mui/icons-material": ">=7.3.1",
    "@mui/material": ">=7.3.1",
    "async-primitives": ">=1.7.0",
    "commander": ">=11.0.0",
    "dayjs": ">=1.11.0",
    "fastify": ">=4.28.1",
    "json5": ">=2.2.0",
    "react": ">=19.1.1",
    "react-dom": ">=19.1.1"
  },
  "devDependencies": {
    "@types/node": ">=20.0.0",
    "@types/react": ">=19.1.10",
    "@types/react-dom": ">=19.1.7",
    "@vitejs/plugin-react": ">=5.0.1",
    "prettier-max": ">=1.14.0",
    "screw-up": ">=1.30.0",
    "typescript": ">=5.0.0",
    "vite": ">=5.0.0",
    "vite-plugin-dts": ">=3.0.0",
    "vitest": ">=1.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
